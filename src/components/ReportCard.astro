---
import Icon from "./Icon.astro";
import type { ReportMeta } from "../lib/reports";
import { withBase } from "../lib/reports";

interface Props {
  report: ReportMeta;
  featured?: boolean;
}

const { report, featured = false } = Astro.props;
---

<a
  class:list={["report-card", `tone-${report.module.tone}`, { featured }]}
  href={withBase(report.url)}
>
  <div class="card-glow"></div>
  <div class="card-topline">
    <span class="card-icon"><Icon name={report.module.icon} size={23} /></span>
    <span class="card-category">{report.module.categoryLabel}</span>
    <span class="card-arrow"><Icon name="arrow" size={19} /></span>
  </div>

  <div class="card-copy">
    <p class="card-date">{report.displayDate}</p>
    <h2>{report.module.name}</h2>
    <p>{report.module.description}</p>
  </div>

  <div class="card-meta">
    <span><Icon name="clock" size={15} /> {report.readingTime}</span>
    <span>开始阅读</span>
  </div>
</a>
