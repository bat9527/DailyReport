---
interface Heading {
  depth: number;
  slug: string;
  text: string;
}

interface Props {
  headings: Heading[];
}

const { headings } = Astro.props;
const sections = headings.filter((heading) => heading.depth === 2).slice(0, 12);
---

{sections.length > 0 && (
  <aside class="article-toc" aria-label="本期目录">
    <p>本期目录</p>
    <ol>
      {sections.map((heading) => (
        <li><a href={`#${heading.slug}`}>{heading.text}</a></li>
      ))}
    </ol>
  </aside>
)}
