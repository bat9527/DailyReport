---
import { getCollection, render, type CollectionEntry } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import ArticleToc from "../components/ArticleToc.astro";
import Icon from "../components/Icon.astro";
import {
  getArchiveEntries,
  metaForEntry,
  pathForEntry,
  withBase,
  type ReportEntry
} from "../lib/reports";

export async function getStaticPaths() {
  const entries = await getCollection("reports");
  return entries.map((entry) => ({
    params: { path: entry.id.replace(/\.md$/, "") },
    props: { entry }
  }));
}

interface Props { entry: CollectionEntry<"reports"> }
const { entry } = Astro.props;
const meta = metaForEntry(entry);
const { Content, headings } = await render(entry);
const moduleArchives = await getArchiveEntries(meta.module.id);
const currentIndex = moduleArchives.findIndex((item) => metaForEntry(item).date === meta.date);
const newer = currentIndex > 0 ? moduleArchives[currentIndex - 1] : undefined;
const older = currentIndex >= 0 && currentIndex < moduleArchives.length - 1
  ? moduleArchives[currentIndex + 1]
  : undefined;
---

<BaseLayout title={meta.title} description={meta.summary} article>
  <main class="article-page">
    <header class="article-header page-shell">
      <a class:list={["article-category", `tone-${meta.module.tone}`]} href={withBase(`/${meta.module.id}/`)}>
        <Icon name={meta.module.icon} size={17} /> {meta.module.name}
      </a>
      <h1>{meta.title}</h1>
      <div class="article-byline">
        <span><Icon name="calendar" size={16} /> {meta.displayDate}</span>
        <span><Icon name="clock" size={16} /> {meta.readingTime}</span>
        <span>北京时间</span>
      </div>
    </header>

    <div class="article-layout page-shell">
      <article class="report-content">
        <Content />
      </article>
      <ArticleToc headings={headings} />
    </div>

    <nav class="article-pagination page-shell" aria-label="上一篇和下一篇">
      {older ? (
        <a href={withBase(pathForEntry(older as ReportEntry))}>
          <span>上一篇</span><strong>{metaForEntry(older as ReportEntry).displayDate}</strong>
        </a>
      ) : <span></span>}
      {newer && (
        <a class="next" href={withBase(pathForEntry(newer as ReportEntry))}>
          <span>下一篇</span><strong>{metaForEntry(newer as ReportEntry).displayDate}</strong>
        </a>
      )}
    </nav>
  </main>
</BaseLayout>
