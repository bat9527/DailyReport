---
import BaseLayout from "../layouts/BaseLayout.astro";
import ReportCard from "../components/ReportCard.astro";
import Icon from "../components/Icon.astro";
import {
  getArchiveEntries,
  getLatestEntry,
  getModules,
  formatDate,
  metaForEntry,
  withBase
} from "../lib/reports";

const modules = getModules();
const latestEntries = await Promise.all(modules.map((module) => getLatestEntry(module.id)));
const moduleCards = modules.map((module, index) => ({
  module,
  report: latestEntries[index] ? metaForEntry(latestEntries[index]!) : undefined
}));
const latestReports = moduleCards.flatMap(({ report }) => report ? [report] : []);
const recentReports = (await getArchiveEntries()).slice(0, 5).map(metaForEntry);
const today = latestReports.map((report) => report.date).sort().at(-1) ?? "";
const todayLabel = today ? formatDate(today) : "等待更新";
---

<BaseLayout>
  <main class="home-page">
    <section class="hero-section">
      <div class="hero-orb orb-one"></div>
      <div class="hero-orb orb-two"></div>
      <div class="hero-content">
        <p class="eyebrow"><span></span> DAILY REPORT · BEIJING TIME</p>
        <h1>今天，<br /><span>值得了解什么？</span></h1>
        <p class="hero-description">
          把每天真正重要的信息，整理成可以长期复用的认知。
        </p>
        <div class="hero-status">
          <span class="status-dot"></span>
          <span>内容已更新</span>
          <strong>{todayLabel}</strong>
        </div>
      </div>
    </section>

    <section class="content-section">
      <div class="section-heading">
        <div>
          <p class="section-kicker">TODAY</p>
          <h2>今日阅读</h2>
        </div>
        <p>{modules.length} 个持续关注的方向</p>
      </div>

      <div class="report-grid">
        {moduleCards.map(({ report, module }, index) => (
          <ReportCard report={report} module={module} featured={index === 0} />
        ))}
      </div>
    </section>

    <section class="content-section recent-section">
      <div class="section-heading">
        <div>
          <p class="section-kicker">RECENT</p>
          <h2>最近更新</h2>
        </div>
        <a class="text-link" href={withBase("/archive/")}>查看全部 <Icon name="arrow" size={16} /></a>
      </div>

      <div class="recent-list">
        {recentReports.map((report) => (
          <a class="recent-item" href={withBase(report.url)}>
            <span class:list={["recent-icon", `tone-${report.module.tone}`]}>
              <Icon name={report.module.icon} size={19} />
            </span>
            <div class="recent-copy">
              <span>{report.module.categoryLabel} · {report.displayDate}</span>
              <strong>{report.title}</strong>
            </div>
            <span class="recent-time">{report.readingTime}</span>
            <Icon name="chevron" size={18} />
          </a>
        ))}
      </div>
    </section>

    <section class="principle-card">
      <span class="principle-icon"><Icon name="book" size={25} /></span>
      <div>
        <p>DAILYREPORT PRINCIPLE</p>
        <h2>不追逐信息，只积累理解。</h2>
        <span>来源可追溯 · 事实与判断分离 · 没有价值时不凑数</span>
      </div>
    </section>
  </main>
</BaseLayout>
